[sub_resource type="GDScript" id="GDScript_2abmi"]
script/source = "extends CharacterBody2D
var o = false
var p = false
var a = false
var b = false
var c = true
var t = true
var rot=.5
const SPEED = 300.0
const JUMP_VELOCITY = -400.0
func next():
	pass
func _physics_process(delta: float) -> void:
	if t:
		t=false
		$walk.play()
		$ani.play(\"wr\")
	if not o:
		position.x-=1
	await get_tree().create_timer(2).timeout
	o=true
	if not p:
		p = true
		$walk.stop()
		$yes.play()
		$ani.play(\"bop\")
	if is_inside_tree():
		await get_tree().create_timer(1).timeout
	if not a:
		$ani.play(\"run\")
		position.x-=2
	if is_inside_tree():
		await get_tree().create_timer(4.25).timeout
	a = true
	if not b:
		$ani.play(\"wu\")
		position.y-=1
	if is_inside_tree():
		await get_tree().create_timer(.8).timeout
	b=true
	$ani.visible = false
\"put finally quote here/yes sound\"
"

